# /etc/claude-pty-controller.env  (chmod 600)
# See docs/ARCHITECTURE.md §5/§13/§14.

# ── Transport ────────────────────────────────────────────────────────────────
# The relay/dashboard endpoint. Production MUST be wss:// (§5).
REMOTE_URL=wss://your-relay.example:9000

# ── Mode A: relay + end-to-end encryption (recommended) ──────────────────────
# Presence of PAIRING_SECRET selects relay/E2EE mode. MUST be high-entropy
# (>= 32 chars). Generate: openssl rand -hex 32   (issue #1)
PAIRING_SECRET=
# Admission token for the relay service (separate from PAIRING_SECRET).
RELAY_TOKEN=
# Enrollment window: set to 1 ONLY while pairing a new dashboard device, then
# unset and restart. With it off, a revoked device cannot re-enroll.
#CPC_ALLOW_ENROLL=1

# ── Mode B: direct wss + bearer (no relay) ───────────────────────────────────
# Leave PAIRING_SECRET empty and set a bearer token instead.
#CONTROL_TOKEN=

# ── Paths ────────────────────────────────────────────────────────────────────
# Controller state (static key + authorized_devices). With StateDirectory= in
# the unit this is /var/lib/claude-pty-controller.
CLAUDE_PTY_HOME=/var/lib/claude-pty-controller
# claude's own config/transcripts dir (defaults to ~/.claude).
#CLAUDE_CONFIG_DIR=/home/claude/.claude

# ── Agent ────────────────────────────────────────────────────────────────────
#AGENT_CMD=claude
ANTHROPIC_API_KEY=
#ANTHROPIC_BASE_URL=https://your-proxy.example

# ── Watchdog (optional) ──────────────────────────────────────────────────────
# Also gate the systemd pet on PTY-reader liveness. Only enable where continuous
# output is expected (an idle reader is healthy and would otherwise look stale).
#CPC_WATCHDOG_READER_STALL_SECS=120

RUST_LOG=info
